/*
  # Cloudflare Pages Security & Cache Headers
  # Avati Safe Storage — avati-safe-storage.pages.dev
*/

/*
  # Global headers for all routes
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # Allow Sanity Studio to iframe this site for Presentation Visual Editing
  Content-Security-Policy: frame-ancestors 'self' https://*.sanity.studio https://sanity.studio

/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.webm
  Cache-Control: public, max-age=86400
  Content-Type: video/webm

/*.jpg
  Cache-Control: public, max-age=86400

/*.webp
  Cache-Control: public, max-age=86400

/*.png
  Cache-Control: public, max-age=86400

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
