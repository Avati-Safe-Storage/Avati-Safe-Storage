# ============================================================
#  Avati Safe Storage — Environment Variables
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local to version control.
# ============================================================

# ── Zoho OAuth (⚠️ Client Secret goes ONLY in Cloudflare Pages env, NOT here) ──
# These are safe to set in the frontend env (they are public-facing IDs)
VITE_ZOHO_CLIENT_ID=your_zoho_client_id_here

# ── Zoho Creator CMS ─────────────────────────────────────────
# Set VITE_CMS_PROVIDER=zoho-creator to activate the Zoho Creator adapter.
# Leave blank to use local hardcoded content (current behavior).
VITE_CMS_PROVIDER=
VITE_ZOHO_CREATOR_ACCOUNT_ID=your_zoho_account_id_here
VITE_ZOHO_CREATOR_APP_NAME=avati-cms

# ── Zoho Flow Webhooks ────────────────────────────────────────
# Paste your Zoho Flow webhook URLs here.
VITE_FLOW_WEBHOOK_CONTACT_CAPTURED=
VITE_FLOW_WEBHOOK_STORAGE_SELECTED=
VITE_FLOW_WEBHOOK_INVENTORY_ENTERED=
VITE_FLOW_WEBHOOK_MEDIA_UPLOADED=
VITE_FLOW_WEBHOOK_QUOTE_REQUESTED=
VITE_FLOW_WEBHOOK_LOGISTICS_PROVIDED=
VITE_FLOW_WEBHOOK_PLAN_SELECTED=
VITE_FLOW_WEBHOOK_RETRIEVAL=
VITE_FLOW_WEBHOOK_PAYMENT_REMINDER=
VITE_FLOW_WEBHOOK_WELCOME=
VITE_FLOW_WEBHOOK_OTP_SEND=

# ── Google Analytics 4 ───────────────────────────────────────
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Search Console ────────────────────────────────────
VITE_GOOGLE_SITE_VERIFICATION=your_verification_token_here

# ── Zoho Books (Organisation ID) ─────────────────────────────
VITE_ZOHO_BOOKS_ORG_ID=your_org_id_here

# ── Google Sheets (legacy — kept for fallback) ───────────────
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_SHEET_ID=YOUR_GOOGLE_SHEET_ID_HERE

# ============================================================
#  Cloudflare Pages Function environment variables
#  Set these in Cloudflare Pages → Settings → Environment variables
#  (NOT in this file — they contain secrets)
# ============================================================
# ZOHO_CLIENT_ID         = same as VITE_ZOHO_CLIENT_ID
# ZOHO_CLIENT_SECRET     = (SECRET — Cloudflare only)
# ZOHO_REFRESH_TOKEN     = (SECRET — Cloudflare only)
# ZOHO_DATACENTER        = in
# ZOHO_BOOKS_ORG_ID      = same as VITE_ZOHO_BOOKS_ORG_ID
# FLOW_OTP_WEBHOOK       = Zoho Flow OTP webhook URL (server-side)
# ============================================================
